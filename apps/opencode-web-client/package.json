{
  "name": "opencode-web-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "opencode-codex-web": "./dist/server/main.js"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/cli/main.ts --port 3456 --no-open",
    "dev:client": "vite",
    "build": "vite build && tsup",
    "build:client": "vite build",
    "build:server": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.25",
    "@hono/node-server": "^1.0.0",
    "commander": "^14.0.3",
    "get-port": "^7.0.0",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0",
    "open": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
