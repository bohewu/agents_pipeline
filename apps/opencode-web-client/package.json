{
  "name": "opencode-web-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "opencode-codex-web": "./dist/server/main.js"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/cli/main.ts --port 3456 --no-open\"",
    "dev:server": "tsx watch src/cli/main.ts --port 3456 --no-open",
    "dev:client": "vite",
    "build": "vite build && tsup",
    "build:client": "vite build",
    "build:server": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.25",
    "@hono/node-server": "^1.0.0",
    "commander": "^12.0.0",
    "get-port": "^7.0.0",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0",
    "open": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
