{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevSpec",
  "description": "Human-readable and pipeline-consumable development specification for BDD/TDD-oriented feature work.",
  "type": "object",
  "required": [
    "title",
    "goal",
    "summary",
    "spec_style",
    "scope",
    "constraints",
    "assumptions",
    "user_stories",
    "scenarios",
    "acceptance_criteria",
    "test_plan",
    "open_questions"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "dev-spec"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "spec_style": {
      "type": "string",
      "enum": ["bdd", "tdd", "hybrid"]
    },
    "scope": {
      "type": "object",
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "user_stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "as_a",
          "i_want",
          "so_that"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^story-[a-z0-9._-]+$"
          },
          "as_a": {
            "type": "string",
            "minLength": 1
          },
          "i_want": {
            "type": "string",
            "minLength": 1
          },
          "so_that": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "story_id",
          "type",
          "given",
          "when",
          "then"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^sc-[a-z0-9._-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "story_id": {
            "type": "string",
            "pattern": "^story-[a-z0-9._-]+$"
          },
          "type": {
            "type": "string",
            "enum": ["happy_path", "edge_case", "failure", "regression"]
          },
          "given": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "then": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^ac-[a-z0-9._-]+$"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "priority",
          "verification"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ac-[a-z0-9._-]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["must", "should", "could"]
          },
          "verification": {
            "type": "string",
            "enum": ["unit", "integration", "e2e", "manual", "mixed"]
          },
          "linked_scenarios": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^sc-[a-z0-9._-]+$"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "test_plan": {
      "type": "object",
      "required": [
        "strategy",
        "test_cases"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["tdd", "bdd", "hybrid"]
        },
        "test_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "level",
              "description",
              "covers"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^tc-[a-z0-9._-]+$"
              },
              "level": {
                "type": "string",
                "enum": ["unit", "integration", "e2e", "manual"]
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "covers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^(ac|sc)-[a-z0-9._-]+$"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
