{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DispatchPlan",
  "type": "object",
  "required": [
    "batches",
    "notes"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "batch_id",
          "task_ids",
          "assigned_executor",
          "parallel",
          "resource_class",
          "max_parallelism",
          "teardown_required",
          "notes"
        ],
        "properties": {
          "batch_id": {
            "type": "string"
          },
          "task_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "assigned_executor": {
            "type": "string"
          },
          "parallel": {
            "type": "boolean"
          },
          "resource_class": {
            "type": "string",
            "enum": [
              "light",
              "process",
              "server",
              "browser"
            ]
          },
          "max_parallelism": {
            "type": "integer",
            "minimum": 1
          },
          "teardown_required": {
            "type": "boolean"
          },
          "timeout_hint_minutes": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "resource_class": {
                  "const": "process"
                }
              }
            },
            "then": {
              "properties": {
                "max_parallelism": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 2
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "resource_class": {
                  "enum": [
                    "server",
                    "browser"
                  ]
                }
              }
            },
            "then": {
              "properties": {
                "task_ids": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "max_parallelism": {
                  "const": 1
                },
                "teardown_required": {
                  "const": true
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
