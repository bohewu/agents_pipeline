{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FlowTaskList",
  "type": "object",
  "required": [
    "tasks"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary",
          "description",
          "primary_output",
          "assigned_agent",
          "effort",
          "verification",
          "repair_budget",
          "resource_class",
          "definition_of_done",
          "atomic"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "primary_output": {
            "type": "string",
            "enum": [
              "design",
              "plan",
              "spec",
              "checklist",
              "analysis",
              "implementation"
            ]
          },
          "assigned_agent": {
            "type": "string",
            "enum": [
              "executor",
              "doc-writer",
              "peon",
              "generalist"
            ]
          },
          "effort": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "verification": {
            "type": "string",
            "enum": [
              "none",
              "basic",
              "strong"
            ]
          },
          "repair_budget": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "resource_class": {
            "type": "string",
            "enum": [
              "light",
              "process",
              "server",
              "browser"
            ]
          },
          "definition_of_done": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "atomic": {
            "const": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
