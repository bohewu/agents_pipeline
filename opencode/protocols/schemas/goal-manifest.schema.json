{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalManifest",
  "type": "object",
  "required": [
    "goal_id",
    "goal",
    "input_mode",
    "default_orchestrator",
    "status",
    "batches"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "user_prompt": {
      "type": "string"
    },
    "input_mode": {
      "type": "string",
      "enum": [
        "freeform",
        "explicit_batches"
      ]
    },
    "default_orchestrator": {
      "type": "string",
      "enum": [
        "orchestrator-flow",
        "orchestrator-pipeline",
        "orchestrator-general",
        "orchestrator-simple"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "blocked",
        "partial",
        "completed",
        "failed",
        "aborted"
      ]
    },
    "current_batch_id": {
      "type": "string"
    },
    "next_recommended_action": {
      "type": "string"
    },
    "goal_dir": {
      "type": "string"
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary",
          "main_task_prompt",
          "orchestrator",
          "status",
          "definition_of_done"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "main_task_prompt": {
            "type": "string",
            "minLength": 1
          },
          "orchestrator": {
            "type": "string",
            "enum": [
              "orchestrator-flow",
              "orchestrator-pipeline",
              "orchestrator-general",
              "orchestrator-simple"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "running",
              "blocked",
              "partial",
              "completed",
              "failed",
              "skipped"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forwarded_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^--.+"
            }
          },
          "definition_of_done": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "linked_run_id": {
            "type": "string"
          },
          "linked_run_dir": {
            "type": "string"
          },
          "artifact_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          },
          "started_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}